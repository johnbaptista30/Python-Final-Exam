shuffle = [5, 7, 10, 1, 2, 4, 9, 8, 3, 6]

print(f"Shuffle list: {shuffle}")

n = len(shuffle)
for i in range(n):
  
    for j in range(0, n - i - 1):
        
        if shuffle[j] > shuffle[j + 1]:
            
            shuffle[j], shuffle[j + 1] = shuffle[j + 1], shuffle[j]

print(f"Sorted list: {shuffle}")
